.git
.gitignore
bin
dist
.rkc
.rkc-*
.venv
**/.venv
.coverage
**/.coverage
coverage.xml
**/coverage.xml
*.test
*.out
**/__pycache__
**/*.pyc

# Ignored local model weights, checkpoints, and compiled runtimes must never be
# streamed to the Docker daemon as incidental build context.
*.gguf
*.ggml
*.safetensors
*.ckpt
*.pt
*.pth
*.onnx
*.tflite
*.h5
*.hdf5
*.weights
pytorch_model*.bin
model*.bin
consolidated*.pth
*.so
*.dylib
*.dll
*.exe
*.a
*.lib
*.o
*.obj
*.wasm
**/*.gguf
**/*.ggml
**/*.safetensors
**/*.ckpt
**/*.pt
**/*.pth
**/*.onnx
**/*.tflite
**/*.h5
**/*.hdf5
**/*.weights
**/pytorch_model*.bin
**/model*.bin
**/consolidated*.pth
**/*.so
**/*.dylib
**/*.dll
**/*.exe
**/*.a
**/*.lib
**/*.o
**/*.obj
**/*.wasm

# Docker builds do not consume repository-local environment files. Excluding
# them keeps credentials and developer-specific configuration out of context.
.env
.env.*
**/.env
**/.env.*
